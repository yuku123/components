{
  "configurations": {
    "engine": {
      "type": "spark",
      "mode": "engine.spark.mode.cluster",
      "properties": {
        "master": "spark://192.168.1.103:7077",
        "appName": "write hive restaurant",
        "spark.sql.warehouse.dir": "hdfs://192.168.1.103:9000/user/hive/warehouse",
        "hive.metastore.uris": "thrift://192.168.1.103:9083",
        "spark.executor.memory": "2g",
        "spark.driver.maxResultSize": "2g",
        "spark.cores.max": "1",
        "jars": "C:\\workspace\\components\\util-bigdata\\target\\util-bigdata-1.0-SNAPSHOT.jar",
        "logLevel": "ERROR"
      }
    },
    "runtimeParameter": {
      "HADOOP_USER_NAME": "piday"
    }
  },
  "workflowNodeList": [
    {
      "nodeId": "start",
      "serviceUnit": "engine.service.empty",
      "connector": {
        "pre": [],
        "post": [
          "input_account",
          "input_account_info",
          "input_desk_info",
          "input_food",
          "input_on_account",
          "input_on_duty",
          "input_order",
          "input_order_creator",
          "input_order_dish"
        ]
      }
    },
    {
      "nodeId": "input_account",
      "name": "input_account",
      "type": "engine.nodeType.resource",
      "serviceUnit": "engine.service.resourceHandler",
      "invokeDynamic": "handleLocalInput",
      "invokeParameter": {
        "localFile": "hdfs://192.168.1.103:9000/user/piday/restaurant/raw/account/account.csv",
        "tempName": "input_local",
        "flush": "yes"
      },
      "connector": {
        "pre": [
          "start"
        ],
        "post": [
          "output_account"
        ]
      }
    },
    {
      "nodeId": "output_account",
      "name": "output_account",
      "type": "engine.nodeType.resource",
      "serviceUnit": "engine.service.resourceHandler",
      "invokeDynamic": "handleHiveOutput",
      "invokeParameter": {
        "tableName": "restaurant.raw_account",
        "tempName": "input_local",
        "flush": "yes"
      },
      "connector": {
        "pre": [
          "input_account"
        ],
        "post": []
